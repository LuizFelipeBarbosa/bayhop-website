---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "BayHop — Generative UI for Bay Area transit",
  description = "Ask in plain language and a language model streams back real Flutter cards — trip plans, live departure boards, place lists, service alerts — rendered live on top of an interactive map.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#5A4BE0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-mist text-ink font-sans antialiased w-full overflow-x-hidden">
    <slot />
  </body>
</html>
