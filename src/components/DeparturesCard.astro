---
// Live departure board: station header with a pulsing "live" dot, then a list of
// upcoming departures (line bullet, destination, platform, minutes). Static port
// of DeparturesCard.dc.html.
import type { Departure } from "../data/transit";
import { departuresSample } from "../data/transit";
import LineBullet from "./LineBullet.astro";

interface Props {
  station?: string;
  updated?: string;
  departures?: Departure[];
}
const { station = "Embarcadero", updated = "9:42", departures: rawDepartures } = Astro.props;
const departures =
  Array.isArray(rawDepartures) && rawDepartures.length ? rawDepartures : departuresSample;
---

<div class="w-full font-sans">
  <div class="mb-[6px] flex items-start justify-between">
    <div>
      <div class="font-display text-[23px] font-bold tracking-[-.2px] text-ink">{station}</div>
      <div class="mt-[2px] text-[12px] text-slate-400">Upcoming departures</div>
    </div>
    <div class="flex items-center gap-[7px] pt-[4px]">
      <span
        class="h-2 w-2 rounded-full animate-bh-live"
        style="background:#2E9E5B; box-shadow:0 0 0 3px rgba(46,158,91,.18);"></span>
      <span class="font-mono text-[11px] text-slate-400">Updated {updated}</span>
    </div>
  </div>
  <div
    class="mt-2 overflow-hidden rounded-[18px] border border-[color:rgba(20,24,28,0.05)] bg-white shadow-[0_8px_22px_rgba(20,24,28,0.06)]"
  >
    {
      departures.map((d) => (
        <div class="flex items-center gap-3 border-t border-[color:rgba(20,24,28,0.05)] px-[14px] py-[13px]">
          <LineBullet label={d.name} color={d.color} variant="pill" />
          <div class="min-w-0 flex-1">
            <div class="overflow-hidden text-ellipsis whitespace-nowrap text-[14px] font-semibold text-ink">
              {d.dest}
            </div>
            <div class="text-[11px] text-slate-300">Platform {d.plat}</div>
          </div>
          <div class="flex items-baseline gap-[3px]">
            <div class="font-mono text-[25px] font-bold text-ink">{d.min}</div>
            <div class="text-[11px] text-slate-300">min</div>
          </div>
        </div>
      ))
    }
  </div>
</div>
