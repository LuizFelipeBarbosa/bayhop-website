---
// "Grounded in real data" — sticky intro + stacked data-source rows.
// Port of the LIVE DATA block from `BayHop Site.dc.html`.
import { dataSources } from "../../data/site";
---

<section id="data" class="mx-auto max-w-[1180px] px-8 py-[60px]">
  <div class="grid grid-cols-1 items-start gap-12 min-[900px]:grid-cols-[340px_1fr]">
    <div class="min-[900px]:sticky min-[900px]:top-[88px]">
      <div class="mb-4 font-mono text-[11.5px] font-semibold uppercase tracking-[.7px] text-brand-purple">
        Grounded in real data
      </div>
      <h2 class="m-0 mb-4 font-display text-[38px] font-bold leading-[1.1] tracking-[-.8px]">
        The cards are live, not mock.
      </h2>
      <p class="m-0 text-[16px] leading-[1.6] text-slate-600">
        Departures, places and routes are pulled from public transit and mapping
        APIs. Missing optional keys degrade <i>per feature</i> — the app still
        launches.
      </p>
    </div>

    <div class="flex flex-col gap-4">
      {
        dataSources.map((d) => (
          <div class="flex items-start gap-5 rounded-[18px] bg-white px-[26px] py-6 shadow-[0_1px_3px_rgba(20,24,28,.08)]">
            <div
              class="flex h-[46px] w-[46px] flex-none items-center justify-center rounded-[13px]"
              style={`background:${d.tint};`}
            >
              <span class="h-[14px] w-[14px] rounded-[5px]" style={`background:${d.color};`} />
            </div>
            <div class="flex-1">
              <div class="mb-[5px] flex flex-wrap items-center gap-2.5">
                <span class="font-display text-[18px] font-bold">{d.name}</span>
                <span class="rounded-md bg-[#F1F4F6] px-2 py-[3px] font-mono text-[10.5px] font-semibold text-slate-400">
                  {d.host}
                </span>
              </div>
              <div class="text-[14px] leading-[1.55] text-slate-600">{d.desc}</div>
            </div>
            <div
              class="flex-none whitespace-nowrap rounded-full px-2.5 py-[5px] font-mono text-[10.5px] font-semibold"
              style={`color:${d.badgeColor}; background:${d.badgeBg};`}
            >
              {d.badge}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
