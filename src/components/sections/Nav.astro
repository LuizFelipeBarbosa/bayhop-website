---
// Sticky, frosted top navigation. Port of the NAV block in `BayHop Site.dc.html`.
import { navLinks, GITHUB_URL } from "../../data/site";
---

<header
  class="sticky top-0 z-[100] border-b border-[rgba(20,24,28,0.07)] bg-[rgba(238,242,244,0.72)]"
  style="backdrop-filter:blur(18px) saturate(180%); -webkit-backdrop-filter:blur(18px) saturate(180%);"
>
  <div class="mx-auto flex h-[64px] max-w-[1180px] items-center justify-between px-[32px]">
    <!-- logo -->
    <div class="flex items-center gap-[11px]">
      <svg width="30" height="30" viewBox="0 0 100 100" aria-hidden="true">
        <defs>
          <linearGradient id="navHop" x1="14" y1="30" x2="86" y2="66" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#0091D2"></stop>
            <stop offset="1" stop-color="#5A4BE0"></stop>
          </linearGradient>
        </defs>
        <path d="M22 64 Q50 -2 78 64" fill="none" stroke="url(#navHop)" stroke-width="9" stroke-linecap="round"></path>
        <circle cx="22" cy="64" r="9" fill="#16191C"></circle>
        <circle cx="78" cy="64" r="9" fill="#16191C"></circle>
      </svg>
      <span class="font-display text-[20px] font-bold tracking-[-0.7px] text-ink">
        Bay<span class="text-gradient">Hop</span>
      </span>
    </div>

    <!-- right: links + GitHub -->
    <nav class="flex items-center gap-[28px]">
      <div class="hidden items-center gap-[28px] md:flex">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-[14px] font-semibold text-slate-600 no-underline transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <a
        href={GITHUB_URL}
        class="flex items-center gap-2 rounded-full bg-ink px-[15px] py-[9px] text-[13.5px] font-semibold text-white no-underline transition-colors hover:bg-[#2A3036]"
      >
        <svg width="15" height="15" viewBox="0 0 16 16" fill="#fff" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>
