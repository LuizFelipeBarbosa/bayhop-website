---
// "Two surfaces, one engine" — the two-tab modes grid.
// Port of the MODES block from `BayHop Site.dc.html`.
import { modes } from "../../data/site";
---

<section id="modes" class="mx-auto max-w-[1180px] px-8 pt-[84px] pb-[30px]">
  <div class="mb-4 font-mono text-[11.5px] font-semibold uppercase tracking-[.7px] text-brand-purple">
    Two surfaces, one engine
  </div>
  <h2 class="m-0 mb-[14px] max-w-[680px] font-display text-[42px] font-bold leading-[1.08] tracking-[-1px]">
    A two-tab experience.
  </h2>
  <p class="m-0 mb-[44px] max-w-[620px] text-[17px] leading-[1.6] text-slate-600">
    Each tab builds its own GenUI session with its own catalog and prompt — over
    a shared <span class="font-mono text-[14px]">IndexedStack</span> shell that
    owns location and itinerary state.
  </p>

  <div class="grid grid-cols-1 gap-6 min-[900px]:grid-cols-2">
    {
      modes.map((m) => (
        <div
          class="rounded-[24px] border-t-4 bg-white p-[34px] shadow-[0_1px_3px_rgba(20,24,28,.08)]"
          style={`border-top-color:${m.accent};`}
        >
          <div class="mb-2 flex items-center gap-3">
            <span class="text-[26px]">{m.icon}</span>
            <div class="font-display text-[24px] font-bold tracking-[-.4px]">{m.name}</div>
          </div>
          <div class="mb-[18px] font-mono text-[11.5px] text-slate-300">{m.file}</div>
          <p class="m-0 mb-5 text-[15px] leading-[1.6] text-slate-600">{m.blurb}</p>
          <div class="flex flex-col gap-[13px]">
            {m.feats.map((f) => (
              <div class="flex items-start gap-[11px]">
                <span
                  class="mt-[7px] h-[7px] w-[7px] flex-none rounded-full"
                  style={`background:${m.accent};`}
                />
                <div class="text-[14px] leading-[1.5] text-slate-700">
                  <b class="text-ink">{f.h}</b> — {f.t}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
