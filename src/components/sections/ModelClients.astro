---
// "Pluggable model clients" — dark rounded panel with a header grid and one
// row per model client. Port of the MODEL CLIENTS block from `BayHop Site.dc.html`.
import { clients } from "../../data/site";
---

<section id="models" class="mx-auto max-w-[1180px] px-8 pt-[50px] pb-[70px]">
  <div class="rounded-[28px] bg-ink px-12 py-[54px] text-dark-text">
    <div class="mb-10 grid grid-cols-1 items-center gap-10 min-[900px]:grid-cols-2">
      <div>
        <div class="mb-4 font-mono text-[11.5px] font-semibold uppercase tracking-[.7px] text-dark-purple">
          Pluggable model clients
        </div>
        <h2 class="m-0 font-display text-[38px] font-bold leading-[1.08] tracking-[-.8px]">
          One interface. Swap the model in a line.
        </h2>
      </div>
      <p class="m-0 text-[16px] leading-[1.65] text-dark-muted">
        Every provider sits behind one <span class="font-mono text-[14px] text-dark-lilac">ModelClient</span>
        abstraction that owns conversation history and exposes the streaming
        response. To switch, pass a different <span class="font-mono text-[14px] text-dark-lilac">modelClientBuilder</span>
        — nothing else changes.
      </p>
    </div>

    <div class="flex flex-col gap-3">
      {
        clients.map((c) => (
          <div class="grid grid-cols-1 items-center gap-5 rounded-2xl border border-white/[0.08] bg-white/[0.04] px-6 py-5 min-[760px]:grid-cols-[1.4fr_1fr_1.1fr_auto]">
            <div>
              <div class="font-mono text-[15px] font-semibold text-dark-text">{c.name}</div>
              <div class="mt-[3px] font-mono text-[11.5px] text-dark-faint">{c.file}</div>
            </div>
            <div>
              <div class="mb-0.5 text-[11px] text-dark-faint">Model</div>
              <div class="font-mono text-[13.5px] text-dark-lilac">{c.model}</div>
            </div>
            <div>
              <div class="mb-0.5 text-[11px] text-dark-faint">API key</div>
              <div class="font-mono text-[12.5px] text-dark-muted">{c.env}</div>
            </div>
            <div
              class="justify-self-end whitespace-nowrap rounded-full px-3 py-1.5 font-mono text-[11px] font-semibold"
              style={`color:${c.statusColor}; background:${c.statusBg};`}
            >
              {c.status}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
