---
// Interactive BayHop phone mockup. Port of BayHop.dc.html (screen content +
// map / route animation / drag / search interaction) wrapped in the IOSDevice
// frame from ios-frame.jsx (used WITHOUT a title -> no nav bar). All map and
// generative data is imported from ../data/transit (never hardcoded).
import BayHopResult from "./BayHopResult.astro";
import {
  bartLines,
  muniLines,
  caltrain,
  stations,
  routePoints,
  suggestions,
  chips,
  nearby,
} from "../data/transit";

interface Props {
  initialCard?: "trip" | "departures" | "alert";
  animateRoute?: boolean;
  showMuni?: boolean;
}
const { initialCard = "trip", animateRoute = true, showMuni = true } = Astro.props;

const muniOpacity = showMuni === false ? 0 : 1;
---

<!-- ===================== iOS DEVICE FRAME (no title -> no nav bar) ===================== -->
<div
  data-phone-root
  class="relative shrink-0 overflow-hidden rounded-[48px]"
  style="width:402px; height:874px; background:#F2F2F7; box-shadow:0 40px 80px rgba(0,0,0,0.18), 0 0 0 1px rgba(0,0,0,0.12); font-family:-apple-system, system-ui, sans-serif; -webkit-font-smoothing:antialiased;"
>
  <!-- dynamic island -->
  <div
    aria-hidden="true"
    class="absolute z-50 rounded-[24px]"
    style="top:11px; left:50%; transform:translateX(-50%); width:126px; height:37px; background:#000;"
  >
  </div>

  <!-- status bar (absolute) -->
  <div class="absolute left-0 right-0 top-0 z-10">
    <div
      class="relative flex w-full items-center justify-center"
      style="gap:154px; padding:21px 24px 19px; box-sizing:border-box; z-index:20;"
    >
      <div class="flex flex-1 items-center justify-center" style="height:22px; padding-top:1.5px;">
        <span style="font-family:-apple-system, 'SF Pro', system-ui; font-weight:590; font-size:17px; line-height:22px; color:#000;">9:41</span>
      </div>
      <div class="flex flex-1 items-center justify-center" style="height:22px; gap:7px; padding-top:1px; padding-right:1px;">
        <svg width="19" height="12" viewBox="0 0 19 12" aria-hidden="true">
          <rect x="0" y="7.5" width="3.2" height="4.5" rx="0.7" fill="#000"></rect>
          <rect x="4.8" y="5" width="3.2" height="7" rx="0.7" fill="#000"></rect>
          <rect x="9.6" y="2.5" width="3.2" height="9.5" rx="0.7" fill="#000"></rect>
          <rect x="14.4" y="0" width="3.2" height="12" rx="0.7" fill="#000"></rect>
        </svg>
        <svg width="17" height="12" viewBox="0 0 17 12" aria-hidden="true">
          <path d="M8.5 3.2C10.8 3.2 12.9 4.1 14.4 5.6L15.5 4.5C13.7 2.7 11.2 1.5 8.5 1.5C5.8 1.5 3.3 2.7 1.5 4.5L2.6 5.6C4.1 4.1 6.2 3.2 8.5 3.2Z" fill="#000"></path>
          <path d="M8.5 6.8C9.9 6.8 11.1 7.3 12 8.2L13.1 7.1C11.8 5.9 10.2 5.1 8.5 5.1C6.8 5.1 5.2 5.9 3.9 7.1L5 8.2C5.9 7.3 7.1 6.8 8.5 6.8Z" fill="#000"></path>
          <circle cx="8.5" cy="10.5" r="1.5" fill="#000"></circle>
        </svg>
        <svg width="27" height="13" viewBox="0 0 27 13" aria-hidden="true">
          <rect x="0.5" y="0.5" width="23" height="12" rx="3.5" stroke="#000" stroke-opacity="0.35" fill="none"></rect>
          <rect x="2" y="2" width="20" height="9" rx="2" fill="#000"></rect>
          <path d="M25 4.5V8.5C25.8 8.2 26.5 7.2 26.5 6.5C26.5 5.8 25.8 4.8 25 4.5Z" fill="#000" fill-opacity="0.4"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- content -->
  <div style="height:100%; display:flex; flex-direction:column;">
    <div style="flex:1; overflow:auto;">

      <!-- ===================== SCREEN CONTENT ===================== -->
      <div
        style="position:relative; width:100%; height:100%; overflow:hidden; background:linear-gradient(180deg,#EEF2F4,#E6EBEE); font-family:'Hanken Grotesk',ui-sans-serif,system-ui,sans-serif;"
      >

        <!-- ===================== MAP ===================== -->
        <svg viewBox="0 0 402 874" width="100%" height="100%" style="position:absolute; inset:0; display:block;" aria-hidden="true">
          <defs>
            <filter id="bh-water" x="-30%" y="-30%" width="160%" height="160%"><feGaussianBlur stdDeviation="9"></feGaussianBlur></filter>
            <filter id="bh-glow" x="-40%" y="-40%" width="180%" height="180%"><feGaussianBlur stdDeviation="3.4"></feGaussianBlur></filter>
          </defs>

          <!-- the Bay (soft) + parks -->
          <rect x="176" y="-80" width="150" height="1040" rx="75" transform="rotate(22 250 400)" fill="#C5DAE6" opacity=".85" filter="url(#bh-water)"></rect>
          <rect x="20" y="470" width="128" height="24" rx="12" transform="rotate(-7 84 482)" fill="#D7E3D2" opacity=".8"></rect>
          <rect x="262" y="206" width="150" height="120" rx="40" fill="#D7E3D2" opacity=".5"></rect>

          <!-- base network (dims when a trip is active) -->
          <g data-base-network style="opacity:1; transition:opacity 600ms ease;">
            <!-- Muni Metro fan -->
            <g style={`opacity:${muniOpacity}; transition:opacity 400ms ease;`}>
              {
                muniLines.map((l) => (
                  <polyline points={l.p} fill="none" stroke={l.c} stroke-width="3.6" stroke-linecap="round" stroke-linejoin="round" opacity=".9" />
                ))
              }
            </g>
            <!-- Caltrain -->
            <polyline points={caltrain} fill="none" stroke="#9B2D3A" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="0.1 9" opacity=".85"></polyline>
            <!-- BART lines (yellow under, east-bay fan, red over) -->
            {
              bartLines.map((l) => (
                <polyline points={l.p} fill="none" stroke={l.c} stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" />
              ))
            }
            <!-- stations -->
            {
              stations.map((s) => (
                <circle cx={s.x} cy={s.y} r={s.r} fill="#ffffff" stroke={s.stroke} stroke-width={s.sw} />
              ))
            }
            <!-- station labels -->
            {
              stations.map(
                (s) =>
                  s.label && (
                    <text
                      x={s.lx}
                      y={s.ly}
                      text-anchor={s.anchor}
                      style="font-family:'JetBrains Mono',monospace; font-size:7.5px; font-weight:600; letter-spacing:.4px; fill:#7E888F; paint-order:stroke; stroke:#EAEEF1; stroke-width:3px; stroke-linejoin:round;"
                    >
                      {s.label}
                    </text>
                  )
              )
            }
          </g>

          <!-- highlighted route -->
          <g data-route-group style="opacity:0; transition:opacity 400ms ease;">
            <polyline data-route-line points={routePoints} fill="none" stroke="#ED1C24" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" opacity=".26" filter="url(#bh-glow)" pathLength="1" stroke-dasharray="1 1" style="stroke-dashoffset:1; transition:stroke-dashoffset 1300ms cubic-bezier(.45,0,.12,1);"></polyline>
            <polyline data-route-line points={routePoints} fill="none" stroke="#ED1C24" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" pathLength="1" stroke-dasharray="1 1" style="stroke-dashoffset:1; transition:stroke-dashoffset 1300ms cubic-bezier(.45,0,.12,1);"></polyline>
          </g>
        </svg>

        <!-- ===================== PINS + USER (overlay) ===================== -->
        <div style="position:absolute; inset:0; z-index:20; pointer-events:none;">
          <!-- user location -->
          <div style="position:absolute; left:289px; top:180px;">
            <div style="position:absolute; left:-14px; top:-14px; width:28px; height:28px; border-radius:50%; background:rgba(10,132,255,.4); animation:bh-pulse 2.6s ease-out infinite;"></div>
            <div style="position:absolute; left:-7px; top:-7px; width:14px; height:14px; border-radius:50%; background:#0A84FF; border:2.5px solid #fff; box-shadow:0 2px 7px rgba(10,132,255,.55);"></div>
          </div>
          <!-- origin -->
          <div data-pin style="position:absolute; left:312px; top:158px; opacity:0; transform:translate(-50%,-50%) translateY(-7px); transition:opacity .5s ease, transform .55s cubic-bezier(.2,1.3,.3,1);">
            <div style="position:relative; display:flex; flex-direction:column; align-items:center;">
              <div style="position:absolute; bottom:16px; white-space:nowrap; background:#16191C; color:#fff; font-size:10px; font-weight:600; padding:3px 8px; border-radius:7px; box-shadow:0 5px 12px rgba(0,0,0,.22);">Downtown Berkeley</div>
              <div style="width:18px; height:18px; border-radius:50%; background:#16191C; border:3px solid #fff; box-shadow:0 3px 8px rgba(0,0,0,.32);"></div>
            </div>
          </div>
          <!-- destination -->
          <div data-pin style="position:absolute; left:236px; top:688px; opacity:0; transform:translate(-50%,-50%) translateY(-7px); transition:opacity .5s ease, transform .55s cubic-bezier(.2,1.3,.3,1);">
            <div style="position:relative; display:flex; flex-direction:column; align-items:center;">
              <div style="position:absolute; bottom:18px; white-space:nowrap; background:#ED1C24; color:#fff; font-size:10px; font-weight:700; padding:3px 9px; border-radius:7px; box-shadow:0 5px 12px rgba(237,28,36,.32);">SFO</div>
              <div style="width:20px; height:20px; border-radius:50%; background:#fff; border:4px solid #ED1C24; box-shadow:0 3px 9px rgba(237,28,36,.4);"></div>
            </div>
          </div>
        </div>

        <!-- ===================== SEARCH BAR ===================== -->
        <div style="position:absolute; top:62px; left:14px; right:14px; z-index:30;">
          <button
            type="button"
            data-search-toggle
            aria-label="Search"
            style="display:block; width:100%; text-align:left; padding:0; border:0; background:transparent; position:relative; height:54px; border-radius:999px; overflow:hidden; box-shadow:0 6px 20px rgba(18,28,38,.16), 0 1px 3px rgba(18,28,38,.1); cursor:text;"
          >
            <div style="position:absolute; inset:0; backdrop-filter:blur(18px) saturate(180%); -webkit-backdrop-filter:blur(18px) saturate(180%); background:rgba(255,255,255,.64);"></div>
            <div style="position:absolute; inset:0; border-radius:999px; border:1px solid rgba(255,255,255,.75); box-shadow:inset 0 1px 1px rgba(255,255,255,.9);"></div>
            <div style="position:relative; z-index:1; height:100%; display:flex; align-items:center; gap:11px; padding:0 8px 0 18px;">
              <svg width="19" height="19" viewBox="0 0 19 19" aria-hidden="true"><circle cx="8" cy="8" r="6.1" fill="none" stroke="#4F585F" stroke-width="2.2"></circle><line x1="12.6" y1="12.6" x2="17.4" y2="17.4" stroke="#4F585F" stroke-width="2.2" stroke-linecap="round"></line></svg>
              <div data-query-label style="flex:1; min-width:0; font-size:16px; font-weight:500; color:#16191C; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Downtown Berkeley → SFO</div>
              <div style="width:38px; height:38px; border-radius:50%; background:#E1E8ED; overflow:hidden; flex:none; box-shadow:inset 0 0 0 1px rgba(20,24,28,.07);">
                <svg width="38" height="38" viewBox="0 0 38 38" aria-hidden="true"><circle cx="19" cy="15" r="6.3" fill="#9BA7AF"></circle><path d="M7 38 C7 28.5 12 24 19 24 C26 24 31 28.5 31 38 Z" fill="#9BA7AF"></path></svg>
              </div>
            </div>
          </button>

          <!-- suggestions -->
          <div data-suggestions style="display:none; margin-top:10px; position:relative; border-radius:24px; overflow:hidden; box-shadow:0 14px 36px rgba(18,28,38,.2);">
            <div style="position:absolute; inset:0; backdrop-filter:blur(22px) saturate(180%); -webkit-backdrop-filter:blur(22px) saturate(180%); background:rgba(255,255,255,.82);"></div>
            <div style="position:relative; z-index:1; padding:6px;">
              <div style="font-size:10.5px; font-weight:700; letter-spacing:.5px; color:#9AA2A9; padding:9px 12px 6px;">TRY ASKING</div>
              {
                suggestions.map((g) => (
                  <button
                    type="button"
                    data-suggestion
                    data-card={g.type}
                    class="hover:bg-[rgba(118,128,138,0.12)]"
                    style="display:flex; width:100%; text-align:left; border:0; background:transparent; align-items:center; gap:12px; padding:11px 12px; border-radius:15px; cursor:pointer;"
                  >
                    <div style={`width:34px; height:34px; border-radius:11px; flex:none; display:flex; align-items:center; justify-content:center; background:${g.tint};`}>
                      {g.icon === "trip" && (
                        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true"><circle cx="4" cy="4" r="2.6" fill="none" stroke="#ED1C24" stroke-width="2" /><circle cx="14" cy="14" r="2.6" fill="#ED1C24" /><path d="M4 7 C4 12 14 6 14 11" fill="none" stroke="#ED1C24" stroke-width="2" stroke-linecap="round" stroke-dasharray="1 3" /></svg>
                      )}
                      {g.icon === "dep" && (
                        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true"><rect x="2" y="3" width="14" height="2.6" rx="1.3" fill="#0091D2" /><rect x="2" y="7.7" width="10" height="2.6" rx="1.3" fill="#0091D2" /><rect x="2" y="12.4" width="13" height="2.6" rx="1.3" fill="#0091D2" /></svg>
                      )}
                      {g.icon === "alert" && (
                        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true"><path d="M9 2 L17 16 L1 16 Z" fill="none" stroke="#E8920B" stroke-width="2" stroke-linejoin="round" /><rect x="8" y="7" width="2" height="4.5" rx="1" fill="#E8920B" /><circle cx="9" cy="13.4" r="1.1" fill="#E8920B" /></svg>
                      )}
                    </div>
                    <div style="flex:1; min-width:0;">
                      <div style="font-weight:600; font-size:14.5px; color:#16191C;">{g.title}</div>
                      <div style="font-size:12px; color:#7A828A;">{g.sub}</div>
                    </div>
                  </button>
                ))
              }
            </div>
          </div>
        </div>

        <!-- ===================== BOTTOM SHEET ===================== -->
        <div
          data-sheet
          style="position:absolute; left:0; right:0; bottom:0; height:770px; transform:translateY(330px); transition:transform 560ms cubic-bezier(.22,1.16,.3,1); z-index:40; will-change:transform; box-shadow:0 -8px 40px rgba(18,28,38,.13);"
        >
          <div style="position:absolute; inset:0; border-radius:30px 30px 0 0; backdrop-filter:blur(26px) saturate(190%); -webkit-backdrop-filter:blur(26px) saturate(190%); background:rgba(255,255,255,.78);"></div>
          <div style="position:absolute; inset:0; border-radius:30px 30px 0 0; border-top:1px solid rgba(255,255,255,.85); box-shadow:inset 0 1px 1px rgba(255,255,255,.9);"></div>

          <div style="position:relative; z-index:1; height:100%; display:flex; flex-direction:column;">
            <!-- drag handle -->
            <div data-drag-handle style="padding:11px 0 7px; cursor:grab; touch-action:none; flex:none;">
              <div style="width:40px; height:5px; border-radius:999px; background:rgba(20,24,28,.18); margin:0 auto;"></div>
            </div>

            <div style="flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding-bottom:120px;">
              <!-- quick chips + nearby (visible at PEEK) -->
              <div style="padding:2px 16px 0; display:flex; gap:8px; align-items:center;">
                {
                  chips.map((c) => (
                    <div style="background:rgba(118,128,138,.11); padding:7px 13px; border-radius:999px; font-size:12.5px; font-weight:600; color:#39424A;">{c.label}</div>
                  ))
                }
              </div>
              <button
                type="button"
                data-nearby
                class="bg-[rgba(118,128,138,0.08)] hover:bg-[rgba(118,128,138,0.14)]"
                style="margin:10px 16px 4px; display:flex; width:calc(100% - 32px); text-align:left; border:0; align-items:center; gap:11px; border-radius:15px; padding:11px 13px; cursor:pointer;"
              >
                <span style="width:9px; height:9px; border-radius:50%; background:#2E9E5B; box-shadow:0 0 0 3px rgba(46,158,91,.18); animation:bh-live 1.4s ease-in-out infinite; flex:none;"></span>
                <div style="flex:1; min-width:0; font-size:13px; color:#39424A;"><b style="color:#16191C;">{nearby.station}</b> · {nearby.name} → {nearby.dest}</div>
                <div style="display:flex; align-items:baseline; gap:3px;"><span style="font-family:'JetBrains Mono',monospace; font-weight:700; font-size:17px; color:#16191C;">{nearby.min}</span><span style="font-size:10px; color:#9AA2A9;">min</span></div>
              </button>

              <!-- ===== CARD AREA ===== -->
              <div style="padding:14px 16px 0;">

                <!-- ===== GENERATING RESULT skeleton ===== -->
                <div data-generating>
                  <div style="display:flex; align-items:center; gap:11px; padding:2px 2px 0;">
                    <div class="animate-bh-spark" style="width:32px; height:32px; border-radius:10px; flex:none; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#0091D2,#5A4BE0); box-shadow:0 5px 13px rgba(90,75,224,.34);">
                      <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 1l1.6 4.4L14 7l-4.4 1.6L8 13l-1.6-4.4L2 7l4.4-1.6z" fill="#fff"></path></svg>
                    </div>
                    <div style="flex:1; min-width:0;">
                      <div style="font-weight:700; font-size:15px; color:#16191C;">Generating result…</div>
                      <div data-gen-sub style="font-size:12px; color:#8A929A;">Planning routes across BART</div>
                    </div>
                  </div>
                  <div style="margin-top:14px; background:#fff; border-radius:22px; padding:16px; border:1px solid rgba(20,24,28,.05); box-shadow:0 10px 26px rgba(20,24,28,.06);">
                    <div style="height:13px; width:34%; border-radius:7px; background:linear-gradient(90deg,#E7EBEE 25%,#F5F8F9 37%,#E7EBEE 63%); background-size:200% 100%; animation:bh-shim 1.25s ease-in-out infinite;"></div>
                    <div style="height:42px; width:60%; border-radius:11px; margin-top:14px; background:linear-gradient(90deg,#E7EBEE 25%,#F5F8F9 37%,#E7EBEE 63%); background-size:200% 100%; animation:bh-shim 1.25s ease-in-out infinite;"></div>
                    <div style="height:9px; width:100%; border-radius:5px; margin-top:20px; background:linear-gradient(90deg,#E7EBEE 25%,#F5F8F9 37%,#E7EBEE 63%); background-size:200% 100%; animation:bh-shim 1.25s ease-in-out infinite;"></div>
                    <div style="height:9px; width:78%; border-radius:5px; margin-top:9px; background:linear-gradient(90deg,#E7EBEE 25%,#F5F8F9 37%,#E7EBEE 63%); background-size:200% 100%; animation:bh-shim 1.25s ease-in-out infinite;"></div>
                  </div>
                </div>

                <!-- ===== READY: pre-rendered result cards (only active is shown) ===== -->
                <div data-result="trip" style="display:none;"><BayHopResult variant="trip" showQuery={false} /></div>
                <div data-result="departures" style="display:none;"><BayHopResult variant="departures" showQuery={false} /></div>
                <div data-result="alert" style="display:none;"><BayHopResult variant="alert" showQuery={false} /></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- home indicator (always on top) -->
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-0 right-0 z-[60] flex items-end justify-center"
    style="height:34px; padding-bottom:8px; pointer-events:none;"
  >
    <div class="rounded-full" style="width:139px; height:5px; background:rgba(0,0,0,0.25);"></div>
  </div>
</div>

<script is:inline define:vars={{ initialCard, animateRoute }}>
  const root = document.querySelector("[data-phone-root]");

  if (root) {
    const labels = {
      trip: "Downtown Berkeley → SFO",
      departures: "Embarcadero · next trains",
      alert: "Yellow Line · status",
    };
    const genSubs = {
      trip: "Planning routes across BART",
      departures: "Reading live arrivals",
      alert: "Checking service status",
    };
    const snapY = { full: 0, half: 330, peek: 600 };
    const SHEET_TRANS = "transform 560ms cubic-bezier(.22,1.16,.3,1)";

    const baseG = root.querySelector("[data-base-network]");
    const routeG = root.querySelector("[data-route-group]");
    const routeLines = root.querySelectorAll("[data-route-line]");
    const pins = root.querySelectorAll("[data-pin]");
    const queryEl = root.querySelector("[data-query-label]");
    const searchToggle = root.querySelector("[data-search-toggle]");
    const suggBox = root.querySelector("[data-suggestions]");
    const suggBtns = root.querySelectorAll("[data-suggestion]");
    const nearbyBtn = root.querySelector("[data-nearby]");
    const sheet = root.querySelector("[data-sheet]");
    const handle = root.querySelector("[data-drag-handle]");
    const genBlock = root.querySelector("[data-generating]");
    const genSubEl = root.querySelector("[data-gen-sub]");
    const results = root.querySelectorAll("[data-result]");

    const st = {
      card: ["trip", "departures", "alert"].includes(initialCard) ? initialCard : "trip",
      snap: "half",
      dragging: false,
      searchOpen: false,
      generating: true,
      routeDrawn: false,
      pinsShown: false,
      tripActive: false,
    };

    function apply() {
      if (baseG) baseG.style.opacity = st.tripActive ? "0.22" : "1";
      if (routeG) routeG.style.opacity = st.tripActive ? "1" : "0";
      routeLines.forEach((l) => {
        l.style.strokeDashoffset = st.routeDrawn ? "0" : "1";
      });
      pins.forEach((p) => {
        p.style.opacity = st.pinsShown ? "1" : "0";
        p.style.transform =
          "translate(-50%,-50%) translateY(" + (st.pinsShown ? "0px" : "-7px") + ")";
      });
      if (queryEl) queryEl.textContent = labels[st.card];
      if (suggBox) suggBox.style.display = st.searchOpen ? "" : "none";
      if (sheet) {
        sheet.style.transition = st.dragging ? "none" : SHEET_TRANS;
        sheet.style.transform = "translateY(" + snapY[st.snap] + "px)";
      }
      if (genBlock) genBlock.style.display = st.generating ? "" : "none";
      if (genSubEl) genSubEl.textContent = genSubs[st.card] || "Composing the best view";
      results.forEach((r) => {
        r.style.display = !st.generating && r.dataset.result === st.card ? "" : "none";
      });
    }

    let genT, t1T;

    function fireTrip(isTrip) {
      clearTimeout(t1T);
      if (!isTrip) {
        st.routeDrawn = false;
        st.pinsShown = false;
        apply();
        return;
      }
      if (animateRoute === false) {
        st.routeDrawn = true;
        st.pinsShown = true;
        apply();
        return;
      }
      st.routeDrawn = false;
      st.pinsShown = false;
      apply();
      requestAnimationFrame(() =>
        setTimeout(() => {
          st.routeDrawn = true;
          apply();
        }, 70)
      );
      t1T = setTimeout(() => {
        st.pinsShown = true;
        apply();
      }, 760);
    }

    function generate(card) {
      const trip = card === "trip";
      clearTimeout(genT);
      clearTimeout(t1T);
      st.card = card;
      st.generating = true;
      st.searchOpen = false;
      st.snap = "half";
      st.tripActive = false;
      st.routeDrawn = false;
      st.pinsShown = false;
      apply();
      const dur = animateRoute === false ? 160 : 820;
      genT = setTimeout(() => {
        st.generating = false;
        st.tripActive = trip;
        apply();
        fireTrip(trip);
      }, dur);
    }

    // --- search toggle ---
    if (searchToggle) {
      searchToggle.addEventListener("click", () => {
        st.searchOpen = !st.searchOpen;
        apply();
      });
    }

    // --- suggestion + nearby selection ---
    suggBtns.forEach((b) => {
      b.addEventListener("click", () => generate(b.dataset.card));
    });
    if (nearbyBtn) {
      nearbyBtn.addEventListener("click", () => generate("departures"));
    }

    // --- bottom-sheet drag ---
    let drag = false,
      startY = 0,
      baseY = 0,
      curY = 0;
    if (handle) {
      handle.addEventListener("pointerdown", (e) => {
        startY = e.clientY;
        baseY = snapY[st.snap];
        curY = baseY;
        drag = true;
        st.dragging = true;
        apply();
        try {
          handle.setPointerCapture(e.pointerId);
        } catch (_) {}
      });
      handle.addEventListener("pointermove", (e) => {
        if (!drag) return;
        let y = baseY + (e.clientY - startY);
        y = Math.max(0, Math.min(600, y));
        curY = y;
        if (sheet) sheet.style.transform = "translateY(" + y + "px)";
      });
      const up = (e) => {
        if (!drag) return;
        drag = false;
        const y = curY;
        const pts = [
          ["full", 0],
          ["half", 330],
          ["peek", 600],
        ];
        let best = "half",
          bd = 1e9;
        pts.forEach(([k, v]) => {
          const d = Math.abs(v - y);
          if (d < bd) {
            bd = d;
            best = k;
          }
        });
        st.dragging = false;
        st.snap = best;
        apply();
        try {
          handle.releasePointerCapture(e.pointerId);
        } catch (_) {}
      };
      handle.addEventListener("pointerup", up);
      handle.addEventListener("pointercancel", up);
    }

    // mount: fire the initial card's generative beat
    generate(st.card);
  }
</script>
